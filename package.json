{
  "name": "pilates",
  "version": "0.0.0",
  "private": true,
  "description": "Headless layout engine for terminal UIs",
  "license": "MIT",
  "author": "Zhijie Wang",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run e2e/",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "gen:unicode": "tsx tools/generate-unicode-tables.ts",
    "bench": "pnpm build && tsx bench/index.ts",
    "ci": "pnpm lint && pnpm build && pnpm typecheck && pnpm test",
    "release:dry": "pnpm -r --filter \"./packages/*\" exec pnpm publish --dry-run --access=public --no-git-checks",
    "release": "pnpm ci && pnpm -r --filter \"./packages/*\" exec pnpm publish --access=public --no-git-checks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@pilates/core": "workspace:*",
    "@pilates/render": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/headless": "^6.0.0",
    "strip-ansi": "^7.2.0",
    "tinybench": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "yoga-layout": "^3.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
